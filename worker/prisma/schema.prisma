generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id // Clerk user ID (user_xxx)
  username    String   @unique
  displayName String?
  avatarUrl   String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sets      Set[]
  likes     Like[]
  reactions Reaction[]
  followers Follow[] @relation("FollowingRelation")
  following Follow[] @relation("FollowerRelation")
}

model Set {
  id          String    @id @default(cuid())
  title       String
  description String
  genre       String
  mood        Mood?
  duration    Int
  audioUrl    String
  coverUrl    String?
  status      SetStatus @default(PENDING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     Like[]
  reactions Reaction[]
}

enum SetStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum Mood {
  HYPNOTIC
  EUPHORIC
  TRIBAL
  FLOATING
  DARK
  MELANCHOLIC
  RAW
  COSMIC
}

model Like {
  userId    String
  setId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  set  Set  @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@id([userId, setId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("FollowerRelation", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("FollowingRelation", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Reaction {
  userId    String
  setId     String
  emoji     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  set  Set  @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@id([userId, setId, emoji])
}
